<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EcommerceMobileApp.Views.AccountDetails"
             Title="My Account">

    <ScrollView>
        <VerticalStackLayout Padding="20"
                         Spacing="20">
            <Grid Padding="20"
          ColumnSpacing="20"
          RowSpacing="20">

            <!-- Define columns (will stretch automatically) -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Define rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>

            <!-- HEADER (full width) -->
                <!-- HEADER ROW -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <Label Text="Account Details"
           FontSize="28"
           FontAttributes="Bold"
           VerticalOptions="Center" />

                    <Button Text="View Coin History"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="10"
            HeightRequest="40"
            Padding="10,5"
            Command="{Binding OpenCoinHistoryCommand}"
            Grid.Column="1" />
                </Grid>


                <!-- PROFILE -->
            <Frame Grid.Row="1" Grid.Column="0"
               Padding="15" CornerRadius="12">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Profile"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="20"
                          RowSpacing="10">

                        <Label Text="Username" FontAttributes="Bold"/>
                        <Label Text="{Binding User.UserName}" Grid.Column="1"/>

                        <Label Text="First Name" Grid.Row="1" FontAttributes="Bold"/>
                        <Label Text="{Binding User.FirstName}" Grid.Row="1" Grid.Column="1"/>

                        <Label Text="Last Name" Grid.Row="2" FontAttributes="Bold"/>
                        <Label Text="{Binding User.LastName}" Grid.Row="2" Grid.Column="1"/>

                        <Label Text="Email" Grid.Row="3" FontAttributes="Bold"/>
                        <Label Text="{Binding User.Email}" Grid.Row="3" Grid.Column="1"/>

                        <Label Text="Role" Grid.Row="4" FontAttributes="Bold"/>
                        <Label Text="{Binding User.Role}" Grid.Row="4" Grid.Column="1"/>

                        <Label Text="Coins" Grid.Row="5" FontAttributes="Bold"/>
                        <Label Text="{Binding User.CoinsBalance}" Grid.Row="5" Grid.Column="1"/>

                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- CONTACT -->
            <Frame Grid.Row="1" Grid.Column="1"
               Padding="15" CornerRadius="12">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Contact"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="20"
                            RowSpacing="10">

                        <Label Text="Phone" FontAttributes="Bold"/>
                        <Label Text="{Binding User.PhoneNumber}" Grid.Column="1"/>

                        <Label Text="Country" Grid.Row="1" FontAttributes="Bold"/>
                        <Label Text="{Binding User.CountryName}" Grid.Row="1" Grid.Column="1"/>

                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- ADDRESS -->
            <Frame Grid.Row="2" Grid.Column="0"
               Padding="15" CornerRadius="12">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Address"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="20"
                             RowSpacing="10">

                        <Label Text="Street" FontAttributes="Bold"/>
                        <Label Text="{Binding User.Street}" Grid.Column="1"/>

                        <Label Text="House Number" Grid.Row="1" FontAttributes="Bold"/>
                        <Label Text="{Binding User.HouseNumber}" Grid.Row="1" Grid.Column="1"/>

                        <Label Text="Flat Number" Grid.Row="2" FontAttributes="Bold"/>
                        <Label Text="{Binding User.FlatNumber}" Grid.Row="2" Grid.Column="1"/>

                        <Label Text="City" Grid.Row="3" FontAttributes="Bold"/>
                        <Label Text="{Binding User.City}" Grid.Row="3" Grid.Column="1"/>

                        <Label Text="Postal Code" Grid.Row="4" FontAttributes="Bold"/>
                        <Label Text="{Binding User.PostalCode}" Grid.Row="4" Grid.Column="1"/>

                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- STATUS -->
            <Frame Grid.Row="2" Grid.Column="1"
               Padding="15" CornerRadius="12">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Account Status"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="20"
                             RowSpacing="10">

                        <Label Text="Authenticated" FontAttributes="Bold"/>
                        <Label Text="{Binding User.IsAuthenticated}" Grid.Column="1"/>

                        <Label Text="Active" Grid.Row="1" FontAttributes="Bold"/>
                        <Label Text="{Binding User.IsActive}" Grid.Row="1" Grid.Column="1"/>

                    </Grid>

                </VerticalStackLayout>
            </Frame>

            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>