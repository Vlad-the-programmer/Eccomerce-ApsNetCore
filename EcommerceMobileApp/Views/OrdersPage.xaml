<ContentPage
    x:Name="OrdersPageView"
    x:Class="EcommerceMobileApp.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F5F5">

    <CollectionView x:Name="OrdersList"
                    Margin="10">

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Padding="12"
       Margin="6"
       CornerRadius="12"
       HasShadow="True"
       BackgroundColor="White">

                    <VerticalStackLayout Spacing="8">

                        <!-- ORDER HEADER -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Code}"
                   FontAttributes="Bold"
                   FontSize="16"/>

                            <!-- STATUS BADGE -->
                            <Frame Grid.Column="1"
       Padding="8,3"
       CornerRadius="10"
       HasShadow="False"
       HorizontalOptions="End"
       VerticalOptions="Center">

                                <Label Text="{Binding OrderStatus}"
           FontSize="12"
           TextColor="White"
           FontAttributes="Bold"/>

                                <Frame.Triggers>

                                    <!-- Pending -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Pending">
                                        <Setter Property="BackgroundColor" Value="#9E9E9E"/>
                                    </DataTrigger>

                                    <!-- Paid -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Paid">
                                        <Setter Property="BackgroundColor" Value="#4CAF50"/>
                                    </DataTrigger>

                                    <!-- Cancelled -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Cancelled">
                                        <Setter Property="BackgroundColor" Value="#F44336"/>
                                    </DataTrigger>

                                    <!-- Processing -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Processing">
                                        <Setter Property="BackgroundColor" Value="#FF9800"/>
                                    </DataTrigger>

                                    <!-- ReadyToShip -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="ReadyToShip">
                                        <Setter Property="BackgroundColor" Value="#3F51B5"/>
                                    </DataTrigger>

                                    <!-- Shipped -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Shipped">
                                        <Setter Property="BackgroundColor" Value="#2196F3"/>
                                    </DataTrigger>

                                    <!-- InDelivery -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="InDelivery">
                                        <Setter Property="BackgroundColor" Value="#00BCD4"/>
                                    </DataTrigger>

                                    <!-- Delivered -->
                                    <DataTrigger TargetType="Frame"
                     Binding="{Binding OrderStatus}"
                     Value="Delivered">
                                        <Setter Property="BackgroundColor" Value="#2E7D32"/>
                                    </DataTrigger>

                                </Frame.Triggers>

                            </Frame>
                        </Grid>

                        <Label Text="{Binding OrderDate, StringFormat='Date: {0:yyyy-MM-dd}'}"
               FontSize="12"
               TextColor="Gray"/>

                        <Label Text="{Binding OrderItems.Count, StringFormat='Items: {0}'}"
               FontSize="13"
               TextColor="Gray"/>

                        <Label Text="{Binding TotalAmount, StringFormat='Total: €{0:F2}'}"
               FontSize="16"
               FontAttributes="Bold"
               TextColor="Green"/>

                        <Grid ColumnDefinitions="*,*">
                            <Label Text="{Binding PaymentMethod}"
                   FontSize="12"
                   TextColor="Gray"/>

                            <Label Grid.Column="1"
                   Text="{Binding DeliveryMethod}"
                   FontSize="12"
                   HorizontalOptions="End"
                   TextColor="Gray"/>
                        </Grid>

                        <!-- 🔥 BUTTON -->
                        <Button Text="View Details"
                                Margin="0,10,0,0"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                Command="{Binding BindingContext.ViewOrderCommand, Source={x:Reference OrdersPageView}}"
                                CommandParameter="{Binding .}"  />

                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>