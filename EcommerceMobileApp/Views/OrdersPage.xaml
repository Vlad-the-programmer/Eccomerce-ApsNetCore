<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EcommerceMobileApp.Views.OrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <CollectionView x:Name="OrdersList"
                    SelectionMode="Single"
                    SelectionChanged="OnOrderSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Padding="10" Margin="5">
                    <VerticalStackLayout>
                        <Label Text="{Binding Code}" FontAttributes="Bold"/>
                        <Label Text="{Binding TotalAmount}"/>
                        <Label Text="{Binding OrderStatus}"/>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
