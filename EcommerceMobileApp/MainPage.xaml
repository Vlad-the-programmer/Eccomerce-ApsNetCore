<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EcommerceMobileApp.MainPage"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Padding="2" Spacing="25">

            <!-- HERO BANNER -->
            <Frame CornerRadius="15"
                   HasShadow="True"
                   Padding="0">
                <Image Source="store_banner.png"
                       Aspect="AspectFill"
                       HeightRequest="180"/>
            </Frame>

            <!-- SEARCH BAR -->
            <SearchBar Placeholder="Search products..."
                       FontSize="16"
                       BackgroundColor="#f2f2f2"
                       HeightRequest="45"
                       SearchCommand="{Binding SearchCommand}" />

            <!-- CATEGORY SECTION -->
            <Label Text="Categories"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <HorizontalStackLayout Spacing="15">
                <Frame Padding="10" CornerRadius="10" BackgroundColor="#eeeeee">
                    <Label Text="Electronics"/>
                </Frame>
                <Frame Padding="10" CornerRadius="10" BackgroundColor="#eeeeee">
                    <Label Text="Fashion"/>
                </Frame>
                <Frame Padding="10" CornerRadius="10" BackgroundColor="#eeeeee">
                    <Label Text="Home"/>
                </Frame>
                <Frame Padding="10" CornerRadius="10" BackgroundColor="#eeeeee">
                    <Label Text="Sports"/>
                </Frame>
            </HorizontalStackLayout>

            <!-- FEATURED PRODUCTS -->
            <Label Text="Featured Products"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,0"/>

            <CollectionView ItemsSource="{Binding FeaturedProducts}"
                            ItemsLayout="VerticalGrid, 2"
                            SelectionMode="Single">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10"
                               CornerRadius="12"
                               BackgroundColor="White"
                               HasShadow="True">

                            <VerticalStackLayout Spacing="8">

                                <Image Source="{Binding Image}"
                                       HeightRequest="120"
                                       Aspect="AspectFit"/>

                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="14"/>

                                <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                       TextColor="Green"
                                       FontSize="14"/>

                                <Button Text="View"
                                        CornerRadius="8"
                                        HeightRequest="35"
                                        Command="{Binding BindingContext.ViewProductCommand,
                                                          Source={x:Reference Name=MainPage}}" />

                            </VerticalStackLayout>

                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- CTA -->
            <Button Text="View All Products"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    Command="{Binding ViewAllProductsCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
