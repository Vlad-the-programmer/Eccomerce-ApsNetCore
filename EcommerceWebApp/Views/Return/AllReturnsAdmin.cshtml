@using EcommerceWebApp.Models.Dtos
@model List<EcommerceWebApp.Models.Dtos.ReturnDto>

@{
    ViewData["Title"] = "All Returns";
}

@section Filters{
    <style>
        .filters-section {
            border: 1px solid #e9ecef;
            border-radius: 12px;
        }

            .filters-section .form-label {
                margin-bottom: 0.25rem;
            }

            .filters-section .form-control,
            .filters-section .form-select {
                border-radius: 10px;
            }

            .filters-section .btn {
                border-radius: 10px;
            }
    /* Your existing styles... */
    .text-warning {
        line-height: 1;
        white-space: nowrap;
    }

    .text-warning i {
        font-size: 0.7rem;
        margin-right: 1px;
    }

    @@media (max-width: 768px) {
        .text-warning i {
            font-size: 0.6rem;
        }
    }

    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
    
    .card-header {
        flex-shrink: 0;
    }
    
    .card-footer {
        flex-shrink: 0;
        padding: 0.75rem 1rem;
    }
    
    .card-body {
        padding: 1rem;
    }
    
    .row {
        display: flex;
        flex-wrap: wrap;
    }
    
    .row > [class*='col-'] {
        display: flex;
        flex-direction: column;
    }
    
    @@media (max-width: 576px) {
        .card-footer .d-flex {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .card-footer .btn,
        .card-footer form {
            width: 100%;
        }
    }
    
    .category-sidebar {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 40px);
        overflow-y: auto;
    }
    
    .category-tree {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .category-tree li {
        margin-bottom: 0.25rem;
    }
    
    .category-tree .category-item {
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    
    .category-tree .category-item > a {
        text-decoration: none;
        color: #495057;
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        transition: all 0.2s;
        background-color: #e9ecef;
    }
    
    .category-tree .category-item > a:hover {
        background-color: #dee2e6;
        color: #0d6efd;
    }
    
    .category-tree .category-item > a.active {
        background-color: #0d6efd;
        color: white;
    }
    
    .subcategory-list {
        list-style: none;
        padding-left: 1.5rem;
        margin: 0.25rem 0 0.5rem 0;
    }
    
    .subcategory-list li {
        margin-bottom: 0.25rem;
    }
    
    .subcategory-list a {
        text-decoration: none;
        color: #6c757d;
        display: block;
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        transition: all 0.2s;
        font-size: 0.9rem;
    }
    
    .subcategory-list a:hover {
        background-color: #e9ecef;
        color: #0d6efd;
    }
    
    .subcategory-list a.active {
        background-color: #0d6efd;
        color: white;
    }
    
    .category-tree .badge, .subcategory-list .badge {
        float: right;
        font-size: 0.65rem;
    }
    
    .filter-header {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #dee2e6;
    }
    
    .filter-section {
        margin-bottom: 1.5rem;
    }
    
    .filter-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: #495057;
    }

    @@media (max-width: 768px) {
        .category-sidebar {
            position: static;
            margin-bottom: 1rem;
        }
    }
</style>

<div class="container-fluid px-0">
    <div class="row">
        <div class="col-lg-12 px-0">
            <!-- Filters Bar -->
                <div class="filters-section bg-white border rounded-3 shadow-sm p-3 mb-4">
                    <form asp-controller="Return"
                          asp-action="Filter"
                          method="get"
                          id="filterForm"
                          onsubmit="return removeEmptyParams(this)">

                        <div class="row g-3 align-items-end">

                            <!-- SEARCH -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Search
                                </label>

                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-search"></i>
                                    </span>

                                    <input name="searchString"
                                           class="form-control"
                                           type="search"
                                           placeholder="Refund code, status..."
                                           value="@Context.Request.Query["searchString"]" />
                                </div>
                            </div>

                            <!-- SEARCH PROPERTY -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Search In
                                </label>

                                <select name="searchProperty" class="form-select">
                                    <option value="">All fields</option>

                                    @if (ViewBag.SearchComboxOptions != null)
                                    {
                                        foreach (var option in ViewBag.SearchComboxOptions as List<SearchComboBoxDto>)
                                        {
                                            <option value="@option.PropertyTitle"
                                                    selected="@(Context.Request.Query["searchProperty"] == option.PropertyTitle)">
                                                @option.DisplayName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- SORT -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Sort by
                                </label>

                                <select name="sortProperty" class="form-select">
                                    <option value="">Default (Newest)</option>

                                    @if (ViewBag.OrderbyComboxOptions != null)
                                    {
                                        foreach (var option in ViewBag.OrderbyComboxOptions as List<SearchComboBoxDto>)
                                        {
                                            <option value="@option.PropertyTitle"
                                                    selected="@(Context.Request.Query["sortProperty"] == option.PropertyTitle)">
                                                @option.DisplayName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- ORDER -->
                            <div class="col-lg-2 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Order
                                </label>

                                <select name="sortAscending" class="form-select">
                                    <option value="false"
                                            selected="@(Context.Request.Query["sortAscending"] != "true")">
                                        Desc ↓
                                    </option>

                                    <option value="true"
                                            selected="@(Context.Request.Query["sortAscending"] == "true")">
                                        Asc ↑
                                    </option>
                                </select>
                            </div>

                            <!-- BUTTONS -->
                            <div class="col-lg-1 col-md-12 d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-funnel"></i>
                                </button>

                                <a href="@Url.Action("Index", "Return")"
                                   class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </div>

                        </div>
                    </form>
                </div>
        </div>
    </div>
</div>
}

<h2 class="mb-4">📦 All Returns (Admin)</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">No returns found.</div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead>
            <tr>
                <th>Refund Code</th>
                <th>Reason</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Created</th>
                <th>Change Status</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.RefundCode</td>
                    <td>@item.Reason</td>
                    <td>@item.RefundAmount?.ToString("C")</td>

                    <td>
                        <span class="badge bg-info">@item.Status</span>
                    </td>

                    <td>
                        @item.DateCreated.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </td>

                    <td>
                        @{
                            var flow = new List<string>
                                {
                                "Pending",
                                "Processing",
                                "Shipped",
                                "Delivered",
                                "Approved",
                                "Refunded"
                                };

                            var currentIndex = flow.IndexOf(item.Status);
                            var hasNext = currentIndex >= 0 && currentIndex < flow.Count - 1;
                            var nextStatus = hasNext ? flow[currentIndex + 1] : null;

                            var canCancel = item.Status != "Cancelled" && item.Status != "Delivered" && item.Status != "Refunded";
                            var canReject = item.Status == "Pending" || item.Status == "Processing";
                        }
                        <div class="d-flex flex-column gap-2">

                            <!-- NEXT STEP BUTTON -->
                            @if (!string.IsNullOrEmpty(nextStatus))
                            {
                                <button class="btn btn-sm btn-primary"
                                        onclick="changeStatus('@item.RefundCode', '@nextStatus')">
                                    ➡️ Next: @nextStatus
                                </button>
                            }

                            <!-- REJECT BUTTON -->
                            @if (canReject)
                            {
                                <button class="btn btn-sm btn-danger"
                                        onclick="changeStatus('@item.RefundCode', 'Rejected')">
                                    ❌ Reject
                                </button>
                            }

                            <!-- CANCEL BUTTON -->
                            @if (canCancel)
                            {
                                <button class="btn btn-sm btn-warning"
                                        onclick="changeStatus('@item.RefundCode', 'Cancelled')">
                                    🚫 Cancel
                                </button>
                            }

                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
                  function changeStatus(refundCode, newStatus) {

            fetch('/returns/change-status', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    refundCode: refundCode,
                    status: newStatus
                })
            })
            .then(async res => {
                const data = await res.json();
                return data;
            })
            .then(data => {
                if (data.success) {
                    // alert('Status updated');
                    location.reload();
                } else {
                    throw new Error(data.message);
                }
            })
            .catch(err => {
                console.log(err.message || "Something went wrong!");
            });
        }

        function showToast(type, message) {
            alert(message); 
        }
    </script>
}