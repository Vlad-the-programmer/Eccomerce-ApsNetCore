@using EcommerceWebApp.Models.Dtos
@model List<EcommerceWebApp.Models.Dtos.RefundDto>

@{
    ViewData["Title"] = "Refunds";
    Layout = "_Layout";
}

@section Filters{
    <style>
        .filters-section {
            border: 1px solid #e9ecef;
            border-radius: 12px;
        }

            .filters-section .form-label {
                margin-bottom: 0.25rem;
            }

            .filters-section .form-control,
            .filters-section .form-select {
                border-radius: 10px;
            }

            .filters-section .btn {
                border-radius: 10px;
            }
    /* Your existing styles... */
    .text-warning {
        line-height: 1;
        white-space: nowrap;
    }

    .text-warning i {
        font-size: 0.7rem;
        margin-right: 1px;
    }

    @@media (max-width: 768px) {
        .text-warning i {
            font-size: 0.6rem;
        }
    }

    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
    
    .card-header {
        flex-shrink: 0;
    }
    
    .card-footer {
        flex-shrink: 0;
        padding: 0.75rem 1rem;
    }
    
    .card-body {
        padding: 1rem;
    }
    
    .row {
        display: flex;
        flex-wrap: wrap;
    }
    
    .row > [class*='col-'] {
        display: flex;
        flex-direction: column;
    }
    
    @@media (max-width: 576px) {
        .card-footer .d-flex {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .card-footer .btn,
        .card-footer form {
            width: 100%;
        }
    }
    
    .category-sidebar {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 40px);
        overflow-y: auto;
    }
    
    .category-tree {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    
    .category-tree li {
        margin-bottom: 0.25rem;
    }
    
    .category-tree .category-item {
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    
    .category-tree .category-item > a {
        text-decoration: none;
        color: #495057;
        display: block;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        transition: all 0.2s;
        background-color: #e9ecef;
    }
    
    .category-tree .category-item > a:hover {
        background-color: #dee2e6;
        color: #0d6efd;
    }
    
    .category-tree .category-item > a.active {
        background-color: #0d6efd;
        color: white;
    }
    
    .subcategory-list {
        list-style: none;
        padding-left: 1.5rem;
        margin: 0.25rem 0 0.5rem 0;
    }
    
    .subcategory-list li {
        margin-bottom: 0.25rem;
    }
    
    .subcategory-list a {
        text-decoration: none;
        color: #6c757d;
        display: block;
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        transition: all 0.2s;
        font-size: 0.9rem;
    }
    
    .subcategory-list a:hover {
        background-color: #e9ecef;
        color: #0d6efd;
    }
    
    .subcategory-list a.active {
        background-color: #0d6efd;
        color: white;
    }
    
    .category-tree .badge, .subcategory-list .badge {
        float: right;
        font-size: 0.65rem;
    }
    
    .filter-header {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #dee2e6;
    }
    
    .filter-section {
        margin-bottom: 1.5rem;
    }
    
    .filter-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: #495057;
    }

    @@media (max-width: 768px) {
        .category-sidebar {
            position: static;
            margin-bottom: 1rem;
        }
    }
</style>

<div class="container-fluid px-0">
    <div class="row">
        <div class="col-lg-12 px-0">
            <!-- Filters Bar -->
                <div class="filters-section bg-white border rounded-3 shadow-sm p-3 mb-4">
                    <form asp-controller="Refunds"
                          asp-action="Filter"
                          method="get"
                          id="filterForm"
                          onsubmit="return removeEmptyParams(this)">

                        <div class="row g-3 align-items-end">

                            <!-- SEARCH -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Search
                                </label>

                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="bi bi-search"></i>
                                    </span>

                                    <input name="searchString"
                                           class="form-control"
                                           type="search"
                                           placeholder="Refund code, status..."
                                           value="@Context.Request.Query["searchString"]" />
                                </div>
                            </div>

                            <!-- SEARCH PROPERTY -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Search In
                                </label>

                                <select name="searchProperty" class="form-select">
                                    <option value="">All fields</option>

                                    @if (ViewBag.SearchComboxOptions != null)
                                    {
                                        foreach (var option in ViewBag.SearchComboxOptions as List<SearchComboBoxDto>)
                                        {
                                            <option value="@option.PropertyTitle"
                                                    selected="@(Context.Request.Query["searchProperty"] == option.PropertyTitle)">
                                                @option.DisplayName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- SORT -->
                            <div class="col-lg-3 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Sort by
                                </label>

                                <select name="sortProperty" class="form-select">
                                    <option value="">Default (Newest)</option>

                                    @if (ViewBag.OrderbyComboxOptions != null)
                                    {
                                        foreach (var option in ViewBag.OrderbyComboxOptions as List<SearchComboBoxDto>)
                                        {
                                            <option value="@option.PropertyTitle"
                                                    selected="@(Context.Request.Query["sortProperty"] == option.PropertyTitle)">
                                                @option.DisplayName
                                            </option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- ORDER -->
                            <div class="col-lg-2 col-md-6">
                                <label class="form-label fw-semibold small text-muted">
                                    Order
                                </label>

                                <select name="sortAscending" class="form-select">
                                    <option value="false"
                                            selected="@(Context.Request.Query["sortAscending"] != "true")">
                                        Desc ↓
                                    </option>

                                    <option value="true"
                                            selected="@(Context.Request.Query["sortAscending"] == "true")">
                                        Asc ↑
                                    </option>
                                </select>
                            </div>

                            <!-- BUTTONS -->
                            <div class="col-lg-1 col-md-12 d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-funnel"></i>
                                </button>

                                <a href="@Url.Action("Index", "Refunds")"
                                   class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-clockwise"></i>
                                </a>
                            </div>

                        </div>
                    </form>
                </div>
        </div>
    </div>
</div>
}

<h2 class="mb-4">💸 Refunds</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No refunds found.
    </div>
}
else
{
    @foreach (var refund in Model)
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>Refund Code:</strong> @refund.Code
                </div>

                <span class="badge bg-@(refund.Status == "Approved" ? "success" :
                                                             refund.Status == "Rejected" ? "danger" :
                                                             refund.Status == "Pending" ? "warning" : "secondary")">
            @refund.Status
        </span>
    </div>

            <div class="card-body">
                <p><strong>Created:</strong> @refund.DateCreated.ToLocalTime().ToString("dd MMM yyyy HH:mm")</p>

                <!-- 🔹 ITEMS -->
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                @foreach (var item in refund.RefundItems)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.Reason</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- 🔹 ACTIONS -->
                <div class="mt-3 d-flex gap-2">

                    @if (refund.Status == "Pending")
                    {
                        <button class="btn btn-success btn-sm"
                                onclick="changeRefundStatus('@refund.Code', 'Approved')">
                            Approve
                        </button>

                        <button class="btn btn-danger btn-sm"
                                onclick="changeRefundStatus('@refund.Code', 'Rejected')">
                            Reject
                        </button>
                    }

                </div>
            </div>
        </div>
    }
}

@section Scripts{
<script>
        function removeEmptyParams(form) {
                const formData = new FormData(form);
                const params = new URLSearchParams();

                for (const [key, value] of formData.entries()) {
                    if (value && value.trim() !== '') {
                        params.append(key, value);
                    }
                }

                const queryString = params.toString();
                const baseUrl = form.action;
                const newUrl = queryString ? baseUrl + '?' + queryString : baseUrl;

                window.location.href = newUrl;
                return false;
            }
    function changeRefundStatus(code, status) {
        fetch('/refunds/change-refund-status', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
            },
            body: JSON.stringify({
                refundCode: code,
                status: status
            })
        })
        .then(res => {
            if (!res.ok) throw new Error("Failed to update");
            location.reload();
        })
        .catch(err => {
            alert(err.message);
        });
    }
</script>
}