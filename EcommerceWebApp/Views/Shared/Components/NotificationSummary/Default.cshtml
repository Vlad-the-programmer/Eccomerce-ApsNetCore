@model EcommerceWebApp.Helpers.ViewComponents.NotificationSummaryViewModel;

<style>
    .notification-badge {
        position: absolute;
        top: 0;
        right: 0;
        transform: translate(30%, -30%);
        font-size: 0.7rem;
        padding: 3px 6px;
    }

</style>


<div class="dropdown">
    <a class="nav-link dropdown-toggle position-relative" href="#" role="button" data-bs-toggle="dropdown">
        <i class="bi bi-bell fs-6"></i>

        @if (Model.Count > 0)
        {
            <span class="badge bg-danger rounded-pill notification-badge">
                @Model.Count
            </span>
        }
    </a>
    
    <ul class="dropdown-menu dropdown-menu-end p-2" style="width: 300px;">
        <li class="dropdown-header fw-bold">Notifications</li>

        @if (Model.Items.Any())
        {
            @foreach (var n in Model.Items)
            {
                <li class="dropdown-item small">
                    <div class="fw-bold">@n.DateCreated.ToString("MMM dd, yyyy, h:mm tt")</div>
                    @{
                        var message = n.Message ?? string.Empty;
                        var truncatedMessage = message.Length > 40
                        ? message.Substring(0, 40) + "..."
                        : message;
                    }
                    @truncatedMessage

                </li>
                <li><hr class="dropdown-divider" /></li>
            }
        }
        else
        {
            <li class="dropdown-item text-muted small">No notifications</li>
        }

        <li class="text-center mt-2">
            <a asp-action="Index" asp-controller="Notification" class="btn btn-primary btn-sm w-100">
                View All
            </a>
        </li>
    </ul>
</div>
