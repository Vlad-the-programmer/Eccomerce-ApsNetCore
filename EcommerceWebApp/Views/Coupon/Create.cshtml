@model EcommerceWebApp.Models.Dtos.CouponCreateUpdateDTO
@{
    ViewData["Title"] = "Create Coupon";
}

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle"></i> Create New Coupon
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Code" class="form-label"></label>
                                <input asp-for="Code" class="form-control" placeholder="e.g., SUMMER2024" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Description" class="form-label"></label>
                                <input asp-for="Description" class="form-control" placeholder="Brief description" />
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DiscountAmount" class="form-label">Discount Amount ($)</label>
                                <input asp-for="DiscountAmount" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="DiscountAmount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DiscountPercentage" class="form-label">Discount Percentage (%)</label>
                                <input asp-for="DiscountPercentage" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                                <small class="text-muted">Leave both empty or use one</small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MinOrderAmount" class="form-label">Minimum Order Amount ($)</label>
                                <input asp-for="MinOrderAmount" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="MinOrderAmount" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="MaxDiscountAmount" class="form-label">Maximum Discount Amount ($)</label>
                                <input asp-for="MaxDiscountAmount" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="MaxDiscountAmount" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" class="form-control" type="datetime-local" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="UsageLimit" class="form-label">Usage Limit</label>
                                <input asp-for="UsageLimit" class="form-control" type="number" />
                                <span asp-validation-for="UsageLimit" class="text-danger small"></span>
                                <small class="text-muted">Total number of times this coupon can be used</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PerUserLimit" class="form-label">Per User Limit</label>
                                <input asp-for="PerUserLimit" class="form-control" type="number" />
                                <span asp-validation-for="PerUserLimit" class="text-danger small"></span>
                                <small class="text-muted">How many times per user (optional)</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="All" class="btn btn-outline-secondary">Back to List</a>
                            <button type="submit" class="btn btn-primary">Create Coupon</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>