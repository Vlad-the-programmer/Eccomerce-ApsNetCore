@using EcommerceWebApp.Models.Dtos
@using Microsoft.AspNetCore.Http;

@model NewOrderViewModel
@{
    Layout = "_OrderLayout";
}

<style>
    #formOverlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        backdrop-filter: blur(3px);
        background-color: rgba(255, 255, 255, 0.3);
        z-index: 999;
        pointer-events: all;
    }

    #orderForm {
        position: relative;
    }

        #orderForm:has(#formOverlay) {
            pointer-events: none;
        }

        #orderForm button[type="submit"]:disabled {
            cursor: not-allowed;
            opacity: 0.6;
        }

    /* Coupon styles */
    .coupon-container {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        border: 1px solid #dee2e6;
    }

    .coupon-applied {
        background-color: #d4edda;
        border-color: #c3e6cb;
    }

    .coupon-error {
        background-color: #f8d7da;
        border-color: #f5c6cb;
    }

    .remove-coupon {
        cursor: pointer;
        color: #dc3545;
        text-decoration: none;
    }

        .remove-coupon:hover {
            text-decoration: underline;
        }
</style>

<script>
    function OnShippingUpdate() {
        // Check if the element exists before accessing it
        const deliverySelect = document.getElementById("ShippingType");
        if (!deliverySelect) {
            console.warn("ShippingType element not found yet");
            return;
        }

        const selectedOption = deliverySelect.options[deliverySelect.selectedIndex];
        if (!selectedOption) {
            console.warn("No option selected in ShippingType");
            return;
        }

        const deliveryCost = parseFloat(selectedOption.getAttribute("data-cost")) || 0;

        // Get base total - remove $ and commas
        const baseTotal = parseFloat('@Model.TotalAmount'.replace('$', '').replace(',', '')) || 0;

        // Get coupon discount and coins
        const couponDiscount = @(ViewBag.CouponDiscount != null ? ViewBag.CouponDiscount : 0);
        const coinsUsed = @(ViewBag.MaxCoinsUsed != null && (int)ViewBag.MaxCoinsUsed > 0 ? ViewBag.MaxCoinsUsed : 0);

        // Calculate new total
        const newTotal = baseTotal + deliveryCost - couponDiscount - coinsUsed;

        // Update delivery cost display
        const deliveryDisplay = document.getElementById("DeliveryCostDisplay");
        if (deliveryDisplay) {
            deliveryDisplay.textContent = deliveryCost.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        }

        // Update coupon discount display
        const couponDisplay = document.getElementById("CouponDiscountDisplay");
        if (couponDisplay) {
            couponDisplay.textContent = couponDiscount.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        }

        // Update coins display - just show the count, not currency
        const coinsDisplayElement = document.getElementById("CoinsDiscountDisplay");
        if (coinsDisplayElement) {
            coinsDisplayElement.textContent = `- ${coinsUsed} coins`;
        }

        console.log("Coins: ", coinsUsed, @ViewBag.MaxCoinsUsed);
        // Update order total
        const orderTotalDisplay = document.getElementById("OrderTotal");
        if (orderTotalDisplay) {
            orderTotalDisplay.textContent = newTotal.toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        }

        // Update hidden total amount
        const totalAmountInput = document.getElementById("TotalAmount");
        if (totalAmountInput) {
            totalAmountInput.value = newTotal;
        }
    }

    // Wait for DOM to be fully loaded before calling OnShippingUpdate
    document.addEventListener("DOMContentLoaded", function() {
        OnShippingUpdate();
    });

    function applyCoupon() {
        const couponCode = document.getElementById("CouponCode").value;
        if (!couponCode) {
            alert("Please enter a coupon code");
            return;
        }

        const formData = new FormData();
        formData.append('couponCode', couponCode);

        fetch('@Url.Action("ApplyCoupon", "Coupon")', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value,
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            return response.json().then(data => {
                if (!response.ok) {
                    throw data;
                }
                return data;
            });
        })
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to apply coupon');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert(error.message || 'An error occurred while applying the coupon');
        });
    }

    function removeCoupon() {
        const couponCode = document.getElementById("CouponCode").value;
        if (!couponCode) {
            alert("No coupon code found to remove");
            return;
        }

        const formData = new FormData();
        formData.append('code', couponCode);

        fetch('@Url.Action("RemoveCoupon", "Coupon")', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value,
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            if (!response.ok) {
                return response.text().then(text => {
                    throw new Error(`Server returned ${response.status}: ${text.substring(0, 200)}`);
                });
            }
            return response.json();
        })
        .then(data => {
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.message || 'Failed to remove coupon');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred while removing the coupon: ' + error.message);
        });
    }
</script>

@section top {
    <div class="jumbotron">
        <h1 class="display-3 text-center">Order</h1>
    </div>
}

@if (ViewBag.CartItems == null || ViewBag.CartItems.Count == 0)
{
    <h2 class="text-info">Cart is empty</h2>
    <br />
    <a href="@Url.Action("index", "products")" class="btn btn-outline-primary btn-block btn-lg margin-mobile">Go back to store</a>
}
else
{
    @if (User.Identity.IsAuthenticated)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            Logged in as @User.Identity.Name!
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <a href="@Url.Action("Login", "Account", new { ReturnUrl = Context.Request.Path + Context.Request.QueryString })" class="nounderline text-dark">
                Login to save your order.
            </a>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <form method="post" id="orderForm" action="@Url.Action("Create", "Orders")">
        @Html.AntiForgeryToken()

        @if (!User.Identity.IsAuthenticated)
        {
            <div id="formOverlay"></div>
        }

        <input type="hidden" class="form-control" asp-for="Customer.CustomerId">

        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="FirstName">First Name</label>
                <input type="text" class="form-control" asp-for="Customer.FirstName" pattern=".{3,64}" required>
            </div>
            <div class="form-group col-md-6">
                <label for="LastName">Last Name</label>
                <input type="text" class="form-control" asp-for="Customer.LastName" pattern=".{3,64}" required>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label for="Email">Email</label>
                <input type="email" class="form-control" asp-for="Customer.Email" pattern=".{5,128}" required>
            </div>
            <div class="form-group col-md-6">
                <label for="Phone">Phone number</label>
                <input type="text" class="form-control" asp-for="Customer.PhoneNumber" pattern=".{7,16}" required>
            </div>
            <div class="form-group col-md-6">
                <label for="Nip">Nip</label>
                <input type="text" class="form-control" asp-for="Customer.Nip" pattern=".{7,16}" required>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-8">
                <label for="Street">Street</label>
                <input type="text" class="form-control" asp-for="Customer.Street" required />
            </div>
            <div class="form-group col-md-2">
                <label for="HouseNumber">House #</label>
                <input type="text" class="form-control" asp-for="Customer.HouseNumber" required />
            </div>
            <div class="form-group col-md-2">
                <label for="FlatNumber">Flat #</label>
                <input type="text" class="form-control" asp-for="Customer.FlatNumber" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group col-md-4">
                <label for="City">City</label>
                <input type="text" class="form-control" asp-for="Customer.City" required />
            </div>
            <div class="form-group col-md-4">
                <label for="State">State/Province</label>
                <input type="text" class="form-control" asp-for="Customer.State" />
            </div>
            <div class="form-group col-md-4">
                <label for="PostalCode">Postal Code</label>
                <input type="text" class="form-control" asp-for="Customer.PostalCode" required />
            </div>
        </div>

        @await Html.PartialAsync("_CountrySelector", Model.Customer.CountryName)

        <!-- Coupon Section -->
        <div class="coupon-container @(!string.IsNullOrEmpty(ViewBag.AppliedCouponCode) ? "coupon-applied" : "")">
            <div class="row">
                <div class="col-md-8">
                    <div class="input-group">
                        <input type="text" id="CouponCode" class="form-control" placeholder="Enter coupon code"
                               value="@ViewBag.AppliedCouponCode" @(!string.IsNullOrEmpty(ViewBag.AppliedCouponCode) ? "disabled" : "") />
                        <div class="input-group-append">
                            @if (string.IsNullOrEmpty(ViewBag.AppliedCouponCode))
                            {
                                <button type="button" class="btn btn-primary" onclick="applyCoupon()">Apply Coupon</button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-danger" onclick="removeCoupon()">Remove Coupon</button>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    @if (!string.IsNullOrEmpty(ViewBag.AppliedCouponCode))
                    {
                        <div class="text-success mt-2">
                            <strong>Coupon applied!</strong>
                            <div class="small">Discount: -@ViewBag.CouponDiscount.ToString("C")</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row form-group">
            <div class="col-6">
                <select class="custom-select" onchange="OnShippingUpdate()" name="DeliveryMethod" id="ShippingType" asp-for="DeliveryMethod">
                    <option value="">-- Select Delivery Method --</option>
                    @if (ViewBag.DeliveryMethods != null && ViewBag.DeliveryMethods.Count != 0)
                    {
                        @foreach (var item in ViewBag.DeliveryMethods as List<DeliveryMethodDTO>)
                        {
                            var selected = Model.DeliveryMethod == item.EnumValue ? "selected" : "";
                            <option value="@item.EnumValue" selected="@selected" data-cost="@item.Cost">
                                @item.MethodName (+@item.Cost.ToString("C"))
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-6">
                <select class="custom-select" asp-for="PaymentMethod" required>
                    @if (ViewBag.PaymentMethods != null && ViewBag.PaymentMethods.Count != 0)
                    {
                        @foreach (var item in ViewBag.PaymentMethods as List<PaymentMethodDTO>)
                        {
                            var selected = Model.PaymentMethod.ToString() == item.PaymentType ? "selected" : "";
                            <option value="@item.EnumValue" selected="@selected">
                                @item.PaymentType
                            </option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="form-group" id="info">
            <p><strong>Delivery Cost: </strong></p>
            <p id="DeliveryCostDisplay">@Decimal.Zero.ToString("C")</p>

            <p><strong>Coupon Discount: </strong></p>
            <p id="CouponDiscountDisplay">
                @{
                    var couponDiscount = ViewBag.CouponDiscount != null
                    ? ((decimal)ViewBag.CouponDiscount).ToString("C")
                    : "$0.00";
                }
                @couponDiscount
            </p>

            <p><strong>Coins applied: </strong></p>
            <p id="CoinsDiscountDisplay">
                - @(ViewBag.MaxCoinsUsed != null && (int)ViewBag.MaxCoinsUsed > 0 ? ViewBag.MaxCoinsUsed : 0) coins
            </p>

            <p><strong>VAT Included: </strong></p>
            <p>@(Model.TaxRate * 100) %</p>

            <input type="hidden" id="TotalAmount" asp-for="TotalAmount" />

            <p><strong>Order Total: </strong></p>
            <p id="OrderTotal">
                @{
                    var total = Model.TotalAmount;
                    if (ViewBag.CouponDiscount != null)
                    {
                        total = Model.TotalAmount - (decimal)ViewBag.CouponDiscount;
                    }
                    if (ViewBag.MaxCoinsUsed != null && (int)ViewBag.MaxCoinsUsed > 0)
                    {
                        total = total - (int)ViewBag.MaxCoinsUsed;
                    }
                }
                @total.ToString("C")
            </p>
        </div>

        <div class="row" style="margin-top: 30px">
            <div class="col-sm-4">
                <a href="@Url.Action("index", "cart")" class="btn btn-outline-primary btn-block btn-lg margin-mobile">Get back to cart</a>
            </div>
            <div class="col-sm-8">
                <button type="submit" class="btn btn-success btn-block btn-lg margin-mobile" @(User.Identity.IsAuthenticated ? "" : "disabled")>
                    Submit order
                </button>
            </div>
        </div>
    </form>
}